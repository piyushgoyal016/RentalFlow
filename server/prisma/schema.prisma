generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------
enum RentalStatus {
  PENDING
  ACTIVE
  COMPLETED
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum AddressType {
  BILLING
  SHIPPING
  BOTH
}

// ---------------------------------------------------------------------------
// IDENTITY & ACCESS MANAGEMENT
// ---------------------------------------------------------------------------
model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id        String    @id @default(uuid())
  firstName String
  lastName  String
  email     String    @unique
  password  String
  phone     String?
  isActive  Boolean   @default(true)
  deletedAt DateTime?

  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Restrict)

  addresses     Address[]
  rentalOrders  RentalOrder[]
  notifications Notification[]
  reviews       Review[]
  cart          Cart?
  auditLogs     AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roleId])
}

model Address {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      AddressType @default(BOTH)
  street    String
  city      String
  state     String
  zipCode   String
  country   String
  isDefault Boolean     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model TokenBlacklist {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
}

// ---------------------------------------------------------------------------
// CATALOG MANAGEMENT
// ---------------------------------------------------------------------------
model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  deletedAt   DateTime?

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id         String   @id @default(uuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  name              String
  description       String?
  barcode           String?   @unique
  qrCode            String?   @unique
  isAvailable       Boolean   @default(true)
  rentalPricePerDay Float
  depositAmount     Float
  stockQuantity     Int       @default(1)
  deletedAt         DateTime?

  images      ProductImage[]
  variants    ProductVariant[]
  rentalItems RentalItem[]
  reviews     Review[]
  cartItems   CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  isPrimary Boolean @default(false)

  @@index([productId])
}

model ProductVariant {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  value     String

  @@index([productId])
}

model Review {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  rating  Int // 1-5
  comment String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// SHOPPING CART (Pre-Rental)
// ---------------------------------------------------------------------------
model Cart {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  quantity Int @default(1)

  @@index([cartId])
  @@index([productId])
}

// ---------------------------------------------------------------------------
// COUPONS & DISCOUNTS
// ---------------------------------------------------------------------------
model Coupon {
  id           String    @id @default(uuid())
  code         String    @unique
  discountPct  Float?
  discountFlat Float?
  maxUsage     Int?
  usageCount   Int       @default(0)
  expiresAt    DateTime?
  isActive     Boolean   @default(true)

  rentalOrders RentalOrder[]

  createdAt DateTime @default(now())
}

// ---------------------------------------------------------------------------
// RENTAL ORDER MANAGEMENT
// ---------------------------------------------------------------------------
model RentalOrder {
  id     String       @id @default(uuid())
  userId String
  user   User         @relation(fields: [userId], references: [id], onDelete: Restrict)
  status RentalStatus @default(PENDING)

  couponId String?
  coupon   Coupon? @relation(fields: [couponId], references: [id], onDelete: SetNull)

  pickupDate DateTime
  returnDate DateTime

  totalCost      Float
  discountAmount Float @default(0)
  finalCost      Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items        RentalItem[]
  payment      Payment?
  deposit      SecurityDeposit?
  returnInspec ReturnInspection?

  @@index([userId])
  @@index([couponId])
}

model RentalItem {
  id            String      @id @default(uuid())
  rentalOrderId String
  rentalOrder   RentalOrder @relation(fields: [rentalOrderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id], onDelete: Restrict)

  quantity    Int
  pricePerDay Float

  @@index([rentalOrderId])
  @@index([productId])
}

model Payment {
  id            String        @id @default(uuid())
  rentalOrderId String        @unique
  rentalOrder   RentalOrder   @relation(fields: [rentalOrderId], references: [id], onDelete: Cascade)
  amount        Float
  status        PaymentStatus @default(PENDING)
  invoiceUrl    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model SecurityDeposit {
  id            String      @id @default(uuid())
  rentalOrderId String      @unique
  rentalOrder   RentalOrder @relation(fields: [rentalOrderId], references: [id], onDelete: Cascade)
  amount        Float
  isRefunded    Boolean     @default(false)
  refundAmount  Float?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model ReturnInspection {
  id                 String      @id @default(uuid())
  rentalOrderId      String      @unique
  rentalOrder        RentalOrder @relation(fields: [rentalOrderId], references: [id], onDelete: Cascade)
  returnedAt         DateTime    @default(now())
  isDamaged          Boolean     @default(false)
  damageReport       String?
  missingAccessories String?
  lateFee            LateFee?
}

model LateFee {
  id                 String           @id @default(uuid())
  returnInspectionId String           @unique
  returnInspection   ReturnInspection @relation(fields: [returnInspectionId], references: [id], onDelete: Cascade)
  daysLate           Int
  penaltyAmount      Float
  isPaid             Boolean          @default(false)
  createdAt          DateTime         @default(now())
}

// ---------------------------------------------------------------------------
// NOTIFICATIONS & AUDITING
// ---------------------------------------------------------------------------
model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // EMAIL_REMINDER, PICKUP, RETURN, LATE_RETURN
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  entity    String
  entityId  String
  details   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
}
